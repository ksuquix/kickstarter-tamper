{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git push * main": "deny",
      "git push * master": "deny",
      "git push * main/*": "deny",
      "git push * master/*": "deny",
      "git push --force*": "deny",
      "git push*": "ask",
      "*": "allow"
    }
  }
}
